{
    "name": "dnd-dsl-workspace",
    "description": "Base workspace package",
    "version": "0.0.1",
    "type": "module",
    "private": true,
    "scripts": {
        "clean": "npm run clean --workspaces",
        "watch": "tsc -b tsconfig.build.json --watch",
        "build": "tsc -b tsconfig.build.json && npm run build --workspaces && node copy-files.cjs",
        "build:clean": "npm run clean && npm run build",
        "langium:generate": "npm run --workspace packages/language langium:generate",
        "langium:watch": "npm run --workspace packages/language langium:watch",
        "test": "npm run --workspace packages/language test"
    },
    "devDependencies": {
        "@types/node": "~20.17.48",
        "langium-cli": "^4.2.0",
        "shx": "~0.4.0",
        "typescript": "~5.8.3"
    },
    "workspaces": [
        "packages/language",
        "packages/cli",
        "packages/extension"
    ],
    "dependencies": {
        "langium": "^4.2.2",
        "vscode-languageserver": "^9.0.1",
        "vscode-languageserver-textdocument": "^1.0.12"
    }
}
