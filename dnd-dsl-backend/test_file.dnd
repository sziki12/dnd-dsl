

world "WorldName"

location "Forest Of The Damned"
	exit "Through the dense forest" to "Cozy Village"
	let DangerLevel = 100

location "High Castle"

	exit "Front Door" to "Cozy Village"
	let Resources = object
		let Food = 50
		let Gold = 2000
		let Soliders = call Random with 50, 100 // Pre defined format or action?? like: Call Random with 50, 100
	end

location "Cozy Village"

	entry "Village Square"
	sublocations
		location "Riverside Tavern"
			exit "Back Door" to "Back Alle" ["Hidden": true] //Other [Indentifiers]
			exit "Front Door" to "Village Square" 
			
		location "Back Alle"
			exit "Main Street" to "Village Square"
			
		location "Village Square"
			exit "Enter Forest" to "Forest Of The Damned" //[Condition: Quest "Rising Dead" Active is true]
			let Resources = object
				let Food = 50
				let Gold = 2000
				let Soliders = call Random with 50, 100
			end
	end
	
		
function Random
	param min
	param max

	let result = - 2 - (10  + 12) / 3 + (5 - 5 * 2) + (12) * 3// Just an example of using math operations, you can replace it with actual random generation logic
	result = call predefined randomfv with "min", "max"
return result

function randomBoolean
let result = call predefined randomfv with 0, 1
return result + 1 == 0 

quest "Rising Dead"

	//Quest status can be: Locked, Available, Active, Completed, Failed
	//status: Available
	//giver: NPC "The King"
	//deadline: 5 days
	
	enabled on true
		/*(event completed "EventName"
		and
		Quest succeded "QuestName")
		or
		(State Party Gold > 150
		and
		Quest failed "QuestName")*/
	
	objective "Geather Bone Fragments"
		//requiered count 3
		//starting count 0
		description
			"Geather bone freagments form the fallen Undead."
		on completed
			//trigger "The Ambush"
			let success = true
			call ActionName with 2, 3
			when true
			do
				success = call ActionName with 4, 5
			end
	
	objective "Deliver to the Village"

		description 
			"Bring it to the Herbalist of the Village."
		//requierement:
			//Party Location is Location "Cozy Village"
		
		//Other examples
		requierement
			//event triggered "EventName"
			//and
			true
			//state CONDITION //Ex: completed on state Party Location == Location "Riverside Tavern" and Faction "King's Guard" AtPeace is true
		
function ActionName
return 5